{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenixSuit",
  "version": "0.2.1",
  "identifier": "com.yuzukitsuru.openixsuit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenixSuit",
        "visible": false,
        "width": 1280,
        "height": 880,
        "minWidth": 1090,
        "minHeight": 880,
        "center": true,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/YuzukiTsuru/OpenixSuit/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVDODI5QjJFNjYyOTIwREYKUldUZklDbG1McHVDWExrZGI0ZUlLNWFsN3dqbHAvcmZDL2NJMlJ2V1YrZ3BRTHZMbjZac29XSEkK"
    }
  }
}